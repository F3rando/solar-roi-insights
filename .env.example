# Optional: API Gateway base URL (no trailing slash). If unset, the app loads
# /processed/v1/summary.json and regions.json from the Vite public folder.
# VITE_API_URL=https://xxxxxxxx.execute-api.us-west-2.amazonaws.com/prod

# --- Push processed JSON to S3 (updates the live API objects Lambda reads)
# Bucket must match Lambda DATA_BUCKET for that API.
# Put this line in EITHER file (already gitignored): .env.local OR .env.publish
# S3_METRICS_BUCKET=datahacks-solarflow-data
# AWS CLI credentials: `aws configure` or env vars — not stored in repo.

# MapTiler (optional — for MapLibre GL terrain + vector 3D-style map; not used by Leaflet)
# https://www.maptiler.com/cloud/
# VITE_MAPTILER_KEY=

# Google Solar API (server/ETL only — do not use VITE_*; never commit the real key)
# GOOGLE_SOLAR_API_KEY=
